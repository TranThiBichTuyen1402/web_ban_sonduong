<!DOCTYPE html>
<html lang="vi">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Thanh toán - BT Beauty</title>
</head>
<body style="background-color: #fdf2f4;">
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card p-4 shadow border-0" style="border-radius: 20px;">
                    <h3 class="text-center fw-bold text-danger mb-4">THÔNG TIN GIAO HÀNG</h3>
                    
                    <form action="/khach/xac-nhan-dat-hang" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và tên người nhận</label>
                            <input type="text" name="hoTenNguoiNhan" class="form-control" value="<%= user.tenKhachHang || user.hoTen %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" name="soDienThoai" class="form-control" placeholder="Nhập số điện thoại để shipper gọi..." required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                            <textarea name="diaChi" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                        </div>

                        <div class="bg-light p-3 rounded mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">Tổng thanh toán:</span>
                                <span class="fw-bold text-danger fs-4"><%= tongCong.toLocaleString() %> đ</span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 py-3 fw-bold" style="border-radius: 10px;">XÁC NHẬN ĐẶT HÀNG</button>
                        
                        <div class="text-center mt-3">
                            <a href="/khach/giohang" class="text-decoration-none text-muted small">← Quay lại giỏ hàng</a>
                        </div>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</body>
</html>