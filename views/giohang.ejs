<!DOCTYPE html>
<html lang="vi">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Giỏ hàng</title>
</head>
<body class="bg-light">
    <div class="container my-5">
        <h2 class="fw-bold mb-4">🛒 Giỏ hàng của bạn</h2>
        <div class="row">
            <div class="col-md-8">
                <div class="card p-3 shadow-sm border-0">
                    <table class="table align-middle">
                        <thead>
                            <tr><th>Sản phẩm</th><th>Giá</th><th>Thao tác</th></tr>
                        </thead>
                        <tbody>
                            <% if (cart && cart.length > 0) { %>
                                <% cart.forEach((item, index) => { %>
                                    <tr>
                                        <td><img src="/<%= item.hinhAnh %>" width="50" class="me-2 text-center"> <%= item.tenSon %></td>
                                        <td class="text-danger fw-bold"><%= item.gia.toLocaleString() %> đ</td>
                                        <td><a href="/khach/remove-from-cart/<%= index %>" class="btn btn-sm btn-outline-secondary">Xóa</a></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="3" class="text-center py-4">Giỏ hàng trống! <a href="/">Mua ngay</a></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 shadow-sm border-0">
                    <h5>Tổng cộng:</h5>
                    <h2 class="text-danger fw-bold"><%= tongCong.toLocaleString() %> đ</h2>
                    <hr>
                    <a href="/khach/thanh-toan" class="btn btn-danger w-100 py-3 fw-bold">TIẾN HÀNH THANH TOÁN</a>
                    <a href="/" class="btn btn-link w-100 mt-2 text-muted">Tiếp tục mua sắm</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>