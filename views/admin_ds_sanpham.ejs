<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Sản Phẩm - BT Beauty Lips</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7f6; }
        .nav-admin { background: #222; } 
        .nav-admin a { color: #ccc !important; margin-right: 20px; text-decoration: none; font-size: 14px; transition: 0.3s; } 
        .nav-admin a:hover { color: #fff !important; }
        .active { color: yellow !important; font-weight: bold; }
        
        .table-container { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        .product-img { width: 50px; height: 50px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd; }
        .btn-action { font-weight: 600; text-decoration: none; font-size: 14px; }
        .badge-stock { font-size: 0.85rem; }
    </style>
</head>
<body>

    <nav class="nav-admin p-3 shadow-sm mb-4">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <div>
                <a href="/">Trang chủ</a>
                <a href="/admin/sanpham" class="active">Danh sách sản phẩm</a>
            </div>
            <span class="text-white small">
                Chào **Admin** | <a href="/logout" class="text-white ms-2">Thoát</a>
            </span>
        </div>
    </nav>

    <div class="container">
        <div class="table-container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold text-uppercase m-0">📦 Quản Lý Sản Phẩm</h3>
                <a href="/admin/them" class="btn btn-primary d-flex align-items-center">
                    <span class="me-1">+</span> Thêm sản phẩm mới
                </a>
            </div>

            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr class="text-center">
                        <th width="5%">ID</th>
                        <th width="20%">Tên son</th>
                        <th width="12%">Giá bán</th>
                        <th width="8%">Tồn</th>
                        <th width="25%">Mô tả</th>
                        <th width="10%">Hình ảnh</th>
                        <th width="15%">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (sanpham.length > 0) { %>
                        <% sanpham.forEach((sp, i) => { %>
                            <tr>
                                <td class="text-center text-muted"><%= i + 1 %></td>
                                
                                <td class="fw-bold text-dark"><%= sp.tenSon %></td> 
                                
                                <td class="text-center text-danger fw-bold">
                                    <%= sp.gia.toLocaleString('vi-VN') %> đ
                                </td>
                                
                                <td class="text-center">
                                    <span class="badge badge-stock <%= sp.soLuongTon > 10 ? 'bg-success' : 'bg-warning' %>">
                                        <%= sp.soLuongTon %>
                                    </span>
                                </td>
                                
                                <td>
                                    <div style="max-height: 60px; overflow: hidden; font-size: 0.9rem; color: #666;">
                                        <%= sp.moTa %>
                                    </div>
                                </td>
                                
                                <td class="text-center">
                                   <img src="/<%= sp.hinhAnh %>" width="80" onerror="this.src='/HinhAnh/default.jpg'">
                                </td>
                                
                                <td class="text-center">
                                    <a href="/admin/sua/<%= sp._id %>" class="btn-action text-primary me-3">
                                        Sửa
                                    </a>
                                    <a href="/admin/xoa/<%= sp._id %>" class="btn-action text-danger" 
                                       onclick="return confirm('Bạn có chắc muốn xóa thỏi son: <%= sp.tenSon %>?')">
                                        Xóa
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Chưa có sản phẩm nào trong cửa hàng.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>