<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập & Đăng ký - LipCare Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
body{
		background: #fdf2f4; 
		height: 100vh;
		display: flex;
		align-items:
		center; justify-content: center;
	}
.auth-container {
		background: #fff; border-radius: 25px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
		overflow: hidden;
		max-width: 1000px;
		width: 95%;
		}
 .auth-side {
		padding: 50px;
		}
.login-side {
		border-right: 1px solid #eee;
		}
.btn-pink { 
		background-color: #bc1c5c;
		color: white;
		border-radius: 10px;
		padding: 12px;
		font-weight: bold;
		border: none;
		transition: 0.3s;
		}
.btn-pink:hover {
		background-color: #9a154a;
		color: white;
		transform: translateY(-2px);
		}
.form-label {
		font-weight: bold;
		font-size: 0.8rem;
		color: #444;
		}
h3 { 
		color: #bc1c5c;
		font-weight: bold;
		margin-bottom: 30px;
		position: relative;
		}
h3::after { 
		content: '';
		position: absolute;
		bottom: -8px; left: 0;
		width: 50px; height: 3px;
		background: #bc1c5c;
		}
.form-control {
		border-radius: 8px;
		padding: 10px;
		background: #f8f9fa;
		border: 1px solid #eee;
		}
    </style>
</head>
<body>

<div class="auth-container">
    <div class="row g-0">
        <div class="col-md-5 auth-side login-side">
            <h3>ĐĂNG NHẬP</h3>
            <p class="text-muted small">Nếu bạn đã có tài khoản rồi!</p>
            <form action="/login" method="POST">
                <div class="mb-3">
                    <label class="form-label text-uppercase">Email</label>
                    <input type="email" name="email" class="form-control" placeholder="Nhập email của bạn" required>
                </div>
                <div class="mb-3">
                    <label class="form-label text-uppercase">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required>
                </div>
                <button type="submit" class="btn btn-pink w-100 mt-3">ĐĂNG NHẬP</button>
            </form>
        </div>

        <div class="col-md-7 auth-side bg-light">
    <h3>TẠO TÀI KHOẢN</h3>
    <p class="text-muted small">Đăng ký bằng email hoặc sử dụng tài khoản Google cho nhanh.</p>
    
    <form action="/register" method="POST">
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label">Email đăng ký*</label>
                <input type="email" name="email" class="form-control" placeholder="Email" required>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-6 mb-3">
                <label class="form-label">Mật khẩu*</label>
                <input type="password" name="password" class="form-control" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Xác nhận mật khẩu*</label>
                <input type="password" class="form-control" required>
            </div>
        </div>
        <button type="submit" class="btn btn-pink w-100">ĐĂNG KÝ NGAY</button>
    </form>

    <div class="d-flex align-items-center my-4">
        <hr class="flex-grow-1">
        <span class="mx-2 text-muted small">HOẶC</span>
        <hr class="flex-grow-1">
    </div>

    <div class="text-center">
    <a href="/auth/google" 
       class="btn w-100 d-flex align-items-center justify-content-center gap-2 py-2"
       style="
           background-color: #f8f9fa; /* Màu xám nhạt thay vì trắng tinh */
           color: #333;
           border: 1px solid #ccc;
           border-radius: 10px;
           font-weight: 600;
           text-decoration: none;
       ">
        <i class="bi bi-shield-lock-fill" style="font-size: 18px;"></i> 
        Đăng nhập qua Google
    </a>
</div>
</div>
    </div>
</div>

</body>
</html>
