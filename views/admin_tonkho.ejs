<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>Quản lý tồn kho</title>
    <style>
        .table img { border-radius: 8px; object-fit: cover; }
        .badge-status { width: 100px; display: inline-block; text-align: center; }
    </style>
</head>
<body class="bg-light">
    <div class="container my-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary"><i class="bi bi-box-seam"></i> BÁO CÁO TỒN KHO</h2>
            <a href="/" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house"></i> Quay lại trang chủ</a>
        </div>

        <div class="card p-4 shadow-sm border-0" style="border-radius: 15px;">
            <table class="table table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th class="text-center">Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end">Giá bán</th>
                        <th class="text-center">Cập nhật nhanh</th>
                    </tr>
                </thead>
                <tbody>
                    <% sanpham.forEach(sp => { %>
                        <tr>
                            <td class="text-center">
                                <img src="/<%= sp.hinhAnh %>" width="80" onerror="this.src='/HinhAnh/default.jpg'">
                            </td>
                            <td>
                                <div class="fw-bold text-dark"><%= sp.tenSon %></div>
                                <small class="text-muted">ID: <%= sp._id %></small>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary fs-6 px-3"><%= sp.soLuongTon || 0 %></span>
                            </td>
                            <td class="text-center">
                                <% if (sp.soLuongTon > 15) { %>
                                    <span class="badge bg-success badge-status"><i class="bi bi-check-circle"></i> Còn hàng</span>
                                <% } else if (sp.soLuongTon > 0) { %>
                                    <span class="badge bg-warning text-dark badge-status"><i class="bi bi-exclamation-triangle"></i> Sắp hết</span>
                                <% } else { %>
                                    <span class="badge bg-danger badge-status"><i class="bi bi-x-circle"></i> Hết hàng</span>
                                <% } %>
                            </td>
                            <td class="text-end text-danger fw-bold">
                                <%= sp.gia.toLocaleString() %> đ
                            </td>
                            <td class="text-center">
                                <form action="/admin/cap-nhat-kho/<%= sp._id %>" method="POST" class="d-flex justify-content-center">
                                    <input type="number" name="soLuongMoi" class="form-control form-control-sm w-50 me-1" value="<%= sp.soLuongTon || 0 %>" min="0">
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        <i class="bi bi-save"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <div class="mt-4 p-3 bg-white rounded shadow-sm border-start border-primary border-4">
            <p class="mb-0 small text-muted">
                <strong>Ghi chú:</strong> <br>
                - <span class="text-success fw-bold">Còn hàng:</span> Số lượng > 15 sản phẩm. <br>
                - <span class="text-warning fw-bold">Sắp hết:</span> Số lượng từ 1 đến 15 (Cần chuẩn bị nhập hàng). <br>
                - <span class="text-danger fw-bold">Hết hàng:</span> Số lượng bằng 0 (Ngưng hiển thị bán lẻ).
            </p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>