<!DOCTYPE html>
<html lang="vi">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Đơn hàng</title>
</head>
<body class="bg-light">
    <div class="container my-5">
        <h2 class="fw-bold text-danger mb-4">📦 QUẢN LÝ ĐƠN HÀNG</h2>
        <div class="card border-0 shadow-sm p-4">
            <table class="table table-hover">
                <thead class="table-danger">
                    <tr>
                        <th>Mã đơn</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td class="fw-bold">#<%= order._id %></td>
                            <td><%= new Date(order.ngayDat).toLocaleString('vi-VN', { hour12: false }) %></td>
                            <td class="text-danger fw-bold"><%= order.tongTien.toLocaleString() %> đ</td>
                            <td>
    <span class="badge <%= order.trangThai === 'Đã nhận hàng' ? 'bg-success' : 'bg-warning text-dark' %>">
        <%= order.trangThai %>
    </span>
</td>
                            <td>
    <span class="badge <%= order.trangThai === 'Đã nhận hàng' ? 'bg-success' : (order.trangThai === 'Đang giao' ? 'bg-info' : 'bg-warning text-dark') %>">
        <%= order.trangThai %>
    </span>
</td>
<td>
    <a href="/khach/don-hang/chi-tiet/<%= order._id %>" class="btn btn-sm btn-info text-white">Xem</a>

    <% if (order.trangThai === 'Đang giao' || order.trangThai === 'Đã duyệt') { %>
        <form action="/khach/da-nhan-hang/<%= order._id %>" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Xác nhận bạn đã nhận được gói hàng này?')">
                Đã nhận được hàng
            </button>
        </form>
    <% } %>
</td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <div class="mt-3"><a href="/" class="text-decoration-none">← Quay lại cửa hàng</a></div>
    </div>
</body>
</html>
