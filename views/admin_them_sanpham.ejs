<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Thêm Sản Phẩm - BT Beauty Lips</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fff5f8; } /* Nền hồng nhạt cho tone-sur-tone */
        .card-custom {
            max-width: 700px;
            margin: 50px auto;
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(214, 51, 132, 0.1);
        }
        .card-header {
            background-color: #d63384;
            color: white;
            border-radius: 20px 20px 0 0 !important;
            text-align: center;
            padding: 20px;
        }
        .btn-submit {
            background-color: #d63384;
            color: white;
            border-radius: 10px;
            padding: 10px;
            font-weight: bold;
        }
        .btn-submit:hover { background-color: #b02a6a; color: white; }
    </style>
</head>
<body>

<div class="container">
    <div class="card card-custom">
        <div class="card-header">
            <h3 class="mb-0">💄 THÊM SẢN PHẨM MỚI</h3>
        </div>
        <div class="card-body p-4">
            <form action="/admin/them" method="POST" enctype="multipart/form-data">
                
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm (Son):</label>
                        <input type="text" name="tenSon" class="form-control" placeholder="Nhập tên son..." required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán (VNĐ):</label>
                        <input type="number" name="gia" class="form-control" placeholder="Vd: 250000" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số lượng tồn:</label>
                        <input type="number" name="soLuongTon" class="form-control" value="0">
                    </div>

<div class="col-md-12 mb-3">
    <label class="form-label fw-bold">Hình ảnh sản phẩm:</label>
    
    <input type="text" name="hinhAnh" class="form-control mb-2" placeholder="Dán link ảnh (nếu có)">

    <div class="input-group">
        <input type="file" name="HinhAnhFile" class="form-control" accept="image/*">
    </div>
</div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Hãng sản xuất:</label>
                        <select name="maHang" class="form-select" required>
                            <option value="">-- Chọn hãng sản xuất --</option>
                            <% hang.forEach(h => { %>
                                <option value="<%= h._id %>"><%= h.tenHang %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Mô tả sản phẩm:</label>
                        <textarea name="moTa" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết về son..."></textarea>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-submit">LƯU SẢN PHẨM</button>
                    <a href="/admin/sanpham" class="btn btn-outline-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>