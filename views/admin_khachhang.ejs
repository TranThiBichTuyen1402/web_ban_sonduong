<!DOCTYPE html>
<html lang="vi">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Quản lý khách hàng</title>
</head>
<body>
    <div class="container my-5">
        <h2 class="fw-bold text-success mb-4">👥 DANH SÁCH KHÁCH HÀNG</h2>
        <div class="card p-4 shadow-sm border-0">
            <table class="table table-hover">
                <thead class="table-success">
                    <tr><th>Tên khách hàng</th><th>Email</th><th>Số điện thoại</th><th>Tên đăng nhập</th></tr>
                </thead>
                <tbody>
                    <% customers.forEach(c => { %>
                        <tr>
                            <td class="fw-bold"><%= c.tenKhachHang %></td>
                            <td><%= c.email %></td>
                            <td><%= c.dienThoai %></td>
                            <td><code class="text-primary"><%= c.tenDangNhap %></code></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <a href="/" class="btn btn-secondary mt-3">Quay lại trang chủ</a>
    </div>
</body>
</html>