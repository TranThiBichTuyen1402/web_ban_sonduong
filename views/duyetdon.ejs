<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý duyệt đơn hàng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #fdf2f4; }
        .table-container { background: white; border-radius: 15px; padding: 20px; shadow: 0 4px 15px rgba(0,0,0,0.05); }
        .table thead { background-color: #ff4d6d; color: white; }
        .btn-approve { background-color: #28a745; color: white; border-radius: 20px; }
        .btn-delete { background-color: #dc3545; color: white; border-radius: 20px; }
    </style>
</head>
<body>

<div class="container mt-5">
    <div class="table-container shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-danger m-0">📦 DANH SÁCH ĐƠN HÀNG CẦN DUYỆT</h3>
            <a href="/admin/sanpham" class="btn btn-outline-secondary btn-sm">Quay lại quản lý SP</a>
        </div>

        <table class="table table-hover align-middle">
            <thead>
                <tr class="text-center">
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% if(orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <tr class="text-center">
                            <td class="small fw-bold text-muted">#<%= order._id.toString().substring(18) %></td>
                            <td class="fw-bold"><%= order.tenNguoiNhan %></td>
                            <td><%= new Date(order.ngayDat).toLocaleDateString('vi-VN') %></td>
                            <td class="text-danger fw-bold"><%= order.tongTien.toLocaleString() %> đ</td>
                           <td>
    <% if(order.trangThai === 'Chờ xác nhận') { %>
        <span class="badge bg-warning text-dark">Chờ xác nhận</span>
    <% } else if(order.trangThai === 'Đang giao' || order.trangThai === 'Đã duyệt') { %>
        <span class="badge bg-info">Đang vận chuyển</span>
    <% } else if(order.trangThai === 'Đã nhận hàng') { %>
        <span class="badge bg-success">✅ Khách đã nhận</span>
    <% } else { %>
        <span class="badge bg-secondary text-white"><%= order.trangThai %></span>
    <% } %>
</td>
                            <td>
								<a href="/admin/cap-nhat-trang-thai/<%= order._id %>/Đã duyệt" 
								   class="btn btn-sm btn-success px-3 me-2 shadow-sm">
								   <i class="bi bi-check-circle"></i> Duyệt đơn
								</a>

								<a href="/admin/cap-nhat-trang-thai/<%= order._id %>/delete" 
								   class="btn btn-sm btn-danger px-3 shadow-sm"
									onclick="return confirm('Cảnh báo: Đơn hàng này sẽ mất vĩnh viễn! Bạn chắc chứ?')">
							   <i class="bi bi-trash"></i> Xóa vĩnh viễn
								</a>
							</td>
						</tr>
								 <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Chưa có đơn hàng nào trong danh sách.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
