<!DOCTYPE html>
<html>
<head>
    <title>Sửa Sản Phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background:#fff5f8;">
<div class="container mt-5">
    <div class="card shadow mx-auto" style="max-width: 600px;">
        <div class="card-header bg-warning text-white text-center"><h3>CẬP NHẬT SẢN PHẨM 💄</h3></div>
        <div class="card-body">
            <form action="/admin/sua/<%= sp._id %>" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Tên son:</label>
                    <input type="text" name="tenSon" class="form-control" value="<%= sp.tenSon %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Giá bán:</label>
                    <input type="number" name="gia" class="form-control" value="<%= sp.gia %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Số lượng tồn:</label>
                    <input type="number" name="soLuongTon" class="form-control" value="<%= sp.soLuongTon %>">
                </div>
                <div class="mb-3">
                    <label class="form-label">Hãng sản xuất:</label>
                    <select name="maHang" class="form-select">
                        <% hang.forEach(h => { %>
                            <option value="<%= h._id %>" <%= sp.maHang && sp.maHang.toString() == h._id.toString() ? 'selected' : '' %> >
                                <%= h.tenHang %>
                            </option>
                        <% }) %>
                    </select>
                </div>
				<div class="mb-3">
    <label class="form-label">Ảnh hiện tại:</label><br>
    <img src="/<%= sp.hinhAnh %>" width="100" class="mb-2 img-thumbnail">
    <input type="file" name="HinhAnhFile" class="form-control" accept="image/*">
    <small class="text-muted">Để trống nếu không muốn đổi ảnh mới</small>
</div>
                <div class="mb-3">
                    <label class="form-label">Mô tả:</label>
                    <textarea name="moTa" class="form-control" rows="3"><%= sp.moTa %></textarea>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Lưu Thay Đổi</button>
                    <a href="/admin/sanpham" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
</body>
</html>