<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>BT Beauty Lips</title>
    <style>
        .card { border-radius: 15px; transition: 0.3s; border: none; }
        .card:hover { transform: translateY(-5px); shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .btn-danger { background-color: #ff4d6d; border: none; border-radius: 20px; }
.table-responsive {
    background: white;
    border-radius: 15px;
    padding: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}
    </style>
</head>
<body style="background-color: #fdf2f4;">
   <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-danger" href="/">💄 BT BEAUTY</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainMenu"> 
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a href="/" class="nav-link">Trang chủ</a></li>
                    <li class="nav-item"><a href="/lien-he" class="nav-link">Liên hệ</a></li>
                    
                    <% if (user) { %>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold text-primary" href="#" data-bs-toggle="dropdown">QUẢN TRỊ</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/admin/sanpham">Sản phẩm</a></li>
                                    <li><a class="dropdown-item" href="/admin/tonkho">Tồn kho</a></li>
                                    <li><a class="dropdown-item" href="/admin/khachhang">Khách hàng</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/admin/duyet-don">Quản lý Đơn hàng</a></li>
                                </ul>
                            </li>
                        <% } else { %>
                            <li class="nav-item"><a href="/khach/don-hang" class="nav-link">Đơn hàng của tôi</a></li>
                            <li class="nav-item px-lg-3">
                                <a href="/khach/giohang" class="nav-link position-relative">
                                    <i class="bi bi-cart3"></i> Giỏ hàng
                                    <span class="badge rounded-pill bg-danger"><%= (typeof cartCount !== 'undefined') ? cartCount : 0 %></span>
                                </a>
                            </li>
                        <% } %>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            Chào, <b><%= user.tenKhachHang || user.hoTen || "Khách" %></b> | 
                            <a href="/logout" class="text-decoration-none text-muted">Thoát</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item mt-2 mt-lg-0">
                            <a href="/login" class="btn btn-outline-danger btn-sm px-4 rounded-pill">Đăng nhập</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h3 class="fw-bold mb-4 text-center text-danger">BỘ SƯU TẬP SON MỚI NHẤT</h3>
        <div class="row g-4">
            <% sanpham.forEach(sp => { %>
               <div class="col-6 col-md-3">
                    <div class="card h-100 p-3 shadow-sm text-center">
                        <img src="<%= sp.hinhAnh.startsWith('http') ? sp.hinhAnh : '/' + sp.hinhAnh %>" 
     class="card-img-top mx-auto" 
     style="height: 200px; object-fit: contain;"
     onerror="this.src='https://via.placeholder.com/150?text=No+Image'">
                        <div class="card-body">
							<h6 class="fw-bold"><%= sp.tenSon %></h6>
							<p class="text-danger fw-bold fs-5"><%= sp.gia.toLocaleString() %> đ</p>

							<% if (user && user.role === 'admin') { %>
								<a href="/admin/tonkho" class="btn btn-outline-primary w-100 rounded-pill">
									<i class="bi bi-gear"></i> Tồn kho
								</a>
							<% } else { %>
							<a href="/khach/add-to-cart/<%= sp._id %>" class="btn btn-danger w-100 rounded-pill">
							<i class="bi bi-cart-plus"></i> Mua ngay
							</a>
							<% } %>
						</div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
<% if (user && user.role !== 'admin' && typeof donhang !== 'undefined') { %>
    <div class="container mt-5 pb-5">
        <h3 class="fw-bold mb-4 text-danger"><i class="bi bi-bag-check"></i> ĐƠN HÀNG CỦA BẠN</h3>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Sản phẩm</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% donhang.forEach(dh => { %>
                        <tr>
                            <td><small class="text-muted">#<%= dh._id.toString().slice(-6) %></small></td>
                            <td><%= new Date(dh.ngayDat).toLocaleDateString('vi-VN') %></td>
                            <td>
                                <% dh.sanpham.forEach(item => { %>
                                    <div class="small">- <%= item.tenSon %> (x<%= item.soLuong %>)</div>
                                <% }) %>
                            </td>
                            <td class="fw-bold text-danger"><%= dh.tongTien.toLocaleString() %> đ</td>
                            <td>
                                <span class="badge rounded-pill <%= dh.trangThai === 'Đã giao' ? 'bg-success' : 'bg-warning text-dark' %>">
                                    <%= dh.trangThai %>
                                </span>
                            </td>
                            <td>
                                <% if (dh.trangThai === 'Đang giao') { %>
                                    <form action="/khach/da-nhan-hang/<%= dh._id %>" method="POST">
                                        <button class="btn btn-sm btn-success rounded-pill">Đã nhận hàng</button>
                                    </form>
                                <% } else { %>
                                    <span class="text-muted small">Hoàn thành</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
<% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
