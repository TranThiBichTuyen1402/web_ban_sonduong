<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>BT Beauty Lips</title>
    <style>
        .card { border-radius: 15px; transition: 0.3s; border: none; }
        .card:hover { transform: translateY(-5px); shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .btn-danger { background-color: #ff4d6d; border: none; border-radius: 20px; }
    </style>
</head>
<body style="background-color: #fdf2f4;">
    <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold text-danger" href="/">💄 BT BEAUTY</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto align-items-center">
    <li class="nav-item"><a href="/" class="nav-link">Trang chủ</a></li>
	<li class="nav-item">
        <a href="/lien-he" class="nav-link">Liên hệ</a>
    </li>
    <% if (user) { %>
        <% if (user.role === 'admin') { %>
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle fw-bold text-primary" href="#" data-bs-toggle="dropdown">QUẢN TRỊ</a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="/admin/sanpham">Sản phẩm</a></li>
                    <li><a class="dropdown-item" href="/admin/tonkho">Tồn kho</a></li>
                    <li><a class="dropdown-item" href="/admin/khachhang">Khách hàng</a></li>
                    <li><hr class="dropdown-divider"></li>
                   <li><a class="dropdown-item" href="/admin/duyet-don">Quản lý Đơn hàng</a></li>
                </ul>
            </li>
        <% } else { %>
            <li class="nav-item"><a href="/khach/don-hang" class="nav-link">Đơn hàng của tôi</a></li>
            <li class="nav-item px-3">
                <a href="/khach/giohang" class="nav-link position-relative">
                    <i class="bi bi-cart3"></i> Giỏ hàng
                    <span class="badge rounded-pill bg-danger"><%= cartCount %></span>
                </a>
            </li>
        <% } %>
        <li class="nav-item ms-2">
            Chào, <b><%= user.tenKhachHang || user.hoTen %></b> | 
            <a href="/logout" class="text-decoration-none text-muted">Thoát</a>
        </li>

    <% } else { %>
        <li class="nav-item">
            <a href="/login" class="btn btn-outline-danger btn-sm px-4 rounded-pill">Đăng nhập</a>
        </li>
    <% } %>
</ul>
        </div>
    </div>
</nav>

    <div class="container mt-5">
        <h3 class="fw-bold mb-4 text-center text-danger">BỘ SƯU TẬP SON MỚI NHẤT</h3>
        <div class="row g-4">
            <% sanpham.forEach(sp => { %>
                <div class="col-md-3">
                    <div class="card h-100 p-3 shadow-sm text-center">
                        <img src="<%= sp.hinhAnh.startsWith('http') ? sp.hinhAnh : '/' + sp.hinhAnh %>" 
     class="card-img-top mx-auto" 
     style="height: 200px; object-fit: contain;"
     onerror="this.src='https://via.placeholder.com/150?text=No+Image'">
                        <div class="card-body">
							<h6 class="fw-bold"><%= sp.tenSon %></h6>
							<p class="text-danger fw-bold fs-5"><%= sp.gia.toLocaleString() %> đ</p>

							<% if (user && user.role === 'admin') { %>
								<a href="/admin/tonkho" class="btn btn-outline-primary w-100 rounded-pill">
									<i class="bi bi-gear"></i> Tồn kho
								</a>
							<% } else { %>
							<a href="/khach/add-to-cart/<%= sp._id %>" class="btn btn-danger w-100 rounded-pill">
							<i class="bi bi-cart-plus"></i> Mua ngay
							</a>
							<% } %>
						</div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>